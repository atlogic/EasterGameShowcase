{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "A game session with checkpoints",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "checkpoints": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "checkpoints"]
    }
  },
  "firestore": {
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Storage for shared games"
    }
  }
}
