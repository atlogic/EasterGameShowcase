rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    match /games/{gameId} {
      allow read, write: if true;
    }

    match /sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
